{
  "name": "gsheet2helios",
  "version": "1.0.0",
  "description": "NestJS service that reads email from Google Sheet (column B, given row) and posts it to helios.gezc.org/setEmail.",
  "license": "MIT",
  "scripts": {
    "start:dev": "ts-node-dev --inspect --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@nestjs/axios": "^3.1.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "axios": "^1.7.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "googleapis": "^140.0.0",
    "joi": "^17.12.3",
    "js-base64": "^3.7.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/nodemailer": "^7.0.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
